{
  "site": "heypiggy.com",
  "version": "v1",
  "selectors": {
    "login_email": "input[type='email']",
    "login_password": "input[type='password']",
    "login_submit": "button[type='submit']",
    "consent_next": "#submit-button-cpx",
    "survey_card": "div.survey-item",
    "survey_card_alt": ".survey-card",
    "survey_clickable": "[style*='cursor: pointer']",
    "primary_buttons": "button, a, [role='button']",
    "survey_submit": "button[type='submit']",
    "captcha_presence": ".recaptcha-checkbox, .g-recaptcha, #recaptcha-anchor, iframe[src*='recaptcha'], [title='reCAPTCHA'], .h-captcha, iframe[src*='hcaptcha'], .cf-turnstile, iframe[src*='turnstile'], .captcha-checkbox, [class*='captcha'], [class*='verify'][class*='human']",
    "captcha_checkbox_targets": ".recaptcha-checkbox, #recaptcha-anchor, .captcha-checkbox, [title='reCAPTCHA'], [class*='recaptcha'][class*='checkbox']"
  },
  "flows": {
    "login": ["https://www.heypiggy.com/login"],
    "dashboard": ["dashboard", "surveys"],
    "survey": ["survey card", "survey active", "survey done"]
  },
  "page_signatures": {
    "login": ["email", "password", "submit"],
    "dashboard": ["survey", "reward", "available"],
    "survey_active": ["next", "submit", "question"],
    "survey_done": ["complete", "reward", "thanks"],
    "captcha": ["captcha", "robot", "human"]
  }
}
