{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensin.ai/schemas/global-brain-policy.schema.json",
  "title": "OpenSIN Global Brain Policy Fact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fact_type",
    "fact_id",
    "timestamp",
    "agent_id",
    "repo",
    "branch",
    "event",
    "classification",
    "source",
    "status"
  ],
  "properties": {
    "fact_type": {
      "type": "string",
      "enum": ["secret_event", "env_event", "policy_decision", "sync_event"]
    },
    "fact_id": { "type": "string", "minLength": 8 },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent_id": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "event": {
      "type": "string",
      "enum": [
        "secret_detected",
        "env_detected",
        "sync_attempted",
        "sync_success",
        "sync_failed",
        "verified",
        "blocked_legacy",
        "policy_decision"
      ]
    },
    "key": { "type": ["string", "null"] },
    "classification": {
      "type": "string",
      "enum": ["secret", "env", "credential", "config", "policy"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "path", "line", "origin"],
      "properties": {
        "file": { "type": "string" },
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 },
        "origin": { "type": "string", "enum": ["local", "ci", "repo", "runtime", "scan"] }
      }
    },
    "target": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "vault": { "type": "string", "const": "infisical" },
        "project_id": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 },
        "folder": { "type": "string", "minLength": 1 },
        "secret_path": { "type": "string", "minLength": 1 }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "synced", "verified", "failed", "blocked"]
    },
    "legacy_flag": { "type": "boolean" },
    "hash": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
    "notes": { "type": "string" },
    "redacted": { "type": "boolean" }
  }
}
