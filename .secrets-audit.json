  "setup_instructions": [
    "1. Geh zu https://eu.infisical.com und logge dich ein",
    "2. Geh zu Project Settings > Service Tokens",
    "3. Erstelle ein Service Token mit name 'heypiggy-worker'",
    "4. Kopiere das Token (es wird nur einmal angezeigt!)",
    "5. Setze es als ENV: export INFISICAL_SERVICE_TOKEN='dein-token'",
    "6. Run: heypiggy-worker sync-envs"
