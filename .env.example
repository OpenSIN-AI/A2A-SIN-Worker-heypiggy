# A2A-SIN-Worker-heypiggy — Required Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# Vision Backend (at least one required)
NVIDIA_API_KEY=
CF_TOKEN=
CF_ACCT=

# Browser Automation
PLAYWRIGHT_WS_ENDPOINT=
DRIVER_TYPE=playwright

# Bridge (optional, for legacy mode)
BRIDGE_MCP_URL=
BRIDGE_HEALTH_URL=
BRIDGE_ADAPTER=opensin

# Platform Credentials (managed via Infisical)
HEYPIGGY_EMAIL=
HEYPIGGY_PASSWORD=

# Feature Flags
VISION_BACKEND=auto
VISION_FREE_PATH=1
SKIP_PREFLIGHT=0
WORKER_ENV=production

# Persona Config
PERSONA_FILE=profiles/default.json

# Budget Controls (EUR)
BUDGET_MAX_EUR=5.00

# Infrastructure
INFISICAL_AUTO_PULL=1
OPENSIN_BRIDGE_V2=1
